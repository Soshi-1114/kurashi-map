# 取得後に .env.local へ。コミットしない。
REINFOLIB_API_KEY=
ESTAT_APP_ID=
OPENAI_API_KEY=

# --- マネタイズ導線（任意・クライアント公開値。秘密情報は入れないこと） ---
# 投げ銭・サポーター支援先URL（Ofuse / Buy Me a Coffee 等）。未設定なら支援ボタンは非表示。
NEXT_PUBLIC_SUPPORT_URL=
# ふるさと納税リンクのURLテンプレート。{keyword} を自治体名で置換する。
# 未設定時はさとふるの検索URLをデフォルト使用（提携ASP確定後にここで差し替え）。
# 例: https://www.satofull.jp/search/?keyword={keyword}
NEXT_PUBLIC_FURUSATO_URL_TEMPLATE=
